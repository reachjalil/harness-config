{
  "name": "harness-config",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --sort run build",
    "check": "pnpm -r --sort run check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "pack:dry-run": "pnpm -r --sort --filter \"./packages/*\" exec npm pack --dry-run",
    "publish:dry-run": "pnpm run pack:dry-run",
    "quality": "pnpm run lint && pnpm run check && pnpm run test && pnpm run build && pnpm run pack:dry-run",
    "test": "pnpm -r --sort run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.7",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
