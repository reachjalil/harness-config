{
  "name": "harness-config",
  "private": true,
  "type": "module",
  "version": "1.0.0-alpha.6",
  "description": "Harness config specification proposal and alpha TypeScript reference implementation for portable AI agent configuration.",
  "homepage": "https://www.harnessconfig.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reachjalil/harness-config.git"
  },
  "bugs": {
    "url": "https://github.com/reachjalil/harness-config/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "harness-config",
    "harnessc",
    "ai-agents",
    "agent-configuration",
    "codex",
    "claude",
    "cursor",
    "gemini",
    "skills",
    "prompts",
    "cli"
  ],
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --sort run build",
    "check": "pnpm -r --sort run check",
    "hf:build": "node scripts/build-huggingface.mjs",
    "hf:publish": "node scripts/publish-huggingface.mjs",
    "hf:publish:dry-run": "node scripts/publish-huggingface.mjs --dry-run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "pack:dry-run": "pnpm -r --sort --filter \"./packages/*\" exec npm pack --dry-run",
    "publish:dry-run": "pnpm run pack:dry-run",
    "quality": "pnpm run lint && pnpm run check && pnpm run test && pnpm run build && pnpm run pack:dry-run",
    "release:notes": "node scripts/extract-release-notes.mjs",
    "release:publish:npm": "node scripts/publish-npm.mjs",
    "release:publish:npm:dry-run": "node scripts/publish-npm.mjs --dry-run",
    "release:verify": "node scripts/verify-release-tag.mjs",
    "test": "node --test scripts/*.test.mjs && pnpm -r --sort run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
