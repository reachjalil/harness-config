{
  "name": "@harnessconfig/cli",
  "version": "1.0.0-alpha.0",
  "description": "CLI for validating, initializing, and activating HarnessConfig repositories.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harnessc": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "pnpm run clean && esbuild ./src/bin.ts ./src/index.ts --bundle --platform=node --format=esm --packages=external --external:@harnessconfig/* --target=node22 --outdir=dist && chmod +x dist/bin.js && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "dependencies": {
    "@harnessconfig/core": "1.0.0-alpha.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
