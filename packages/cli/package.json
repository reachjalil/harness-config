{
  "name": "@harnessconfig/cli",
  "version": "1.0.0-alpha.6",
  "description": "Alpha scoped implementation package for the harnessc CLI.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "homepage": "https://www.harnessconfig.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reachjalil/harness-config.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/reachjalil/harness-config/issues"
  },
  "keywords": [
    "harness-config",
    "harnessc",
    "cli",
    "ai-agents",
    "agent-configuration",
    "codex",
    "claude",
    "cursor",
    "gemini"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harnessc": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "pnpm run clean && esbuild ./src/bin.ts ./src/index.ts --bundle --platform=node --format=esm --packages=external --external:@harnessconfig/* --target=node22 --outdir=dist && chmod +x dist/bin.js && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "dependencies": {
    "@harnessconfig/core": "1.0.0-alpha.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
