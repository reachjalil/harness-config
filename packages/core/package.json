{
  "name": "@harnessconfig/core",
  "version": "1.0.0-alpha.4",
  "description": "Alpha TypeScript core for the Harness config specification proposal: validation, projection, profiles, ignores, dir composition, and activation planning.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "homepage": "https://www.harnessconfig.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reachjalil/harness-config.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/reachjalil/harness-config/issues"
  },
  "keywords": [
    "harness-config",
    "ai-agents",
    "agent-configuration",
    "projection",
    "codex",
    "claude",
    "cursor",
    "gemini",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "pnpm run clean && esbuild ./src/index.ts --bundle --platform=node --format=esm --packages=external --target=node22 --outfile=dist/index.js && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "dependencies": {
    "smol-toml": "^1.6.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
