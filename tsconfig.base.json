{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@harnessconfig/core": ["packages/core/src/index.ts"],
      "@harnessconfig/cli": ["packages/cli/src/index.ts"],
      "@harnessconfig/extension-dir": ["packages/extension-dir/src/index.ts"]
    }
  }
}
